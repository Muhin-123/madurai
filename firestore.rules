rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isWardOfficer() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ward_officer';
    }

    function isWardOfficerForWard(ward) {
      return isWardOfficer() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.ward == ward;
    }

    function isSeller(resource) {
      return isAuthenticated() && resource.data.sellerId == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
      allow update: if request.auth.uid == userId && !('role' in request.resource.data.diff(resource.data).affectedKeys());
    }

    match /complaints/{complaintId} {
      allow read: if true;
      allow create: if true;
      allow update: if isAdmin() || isWardOfficerForWard(resource.data.ward);
      allow delete: if isAdmin();
    }

    match /toilet_complaints/{id} {
      allow read: if true;
      allow create: if true;
      allow update: if isAdmin() || isWardOfficerForWard(resource.data.ward);
      allow delete: if isAdmin();
    }

    match /wards/{wardId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /bio_waste_market/{listingId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAdmin() || isSeller(resource);
      allow delete: if isAdmin() || isSeller(resource);
    }

    match /reports/{reportId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
