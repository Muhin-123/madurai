rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // USERS COLLECTION
    // Each user can only read/write their own document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Allow authenticated users to access other collections
    // Modify based on your app requirements
    match /complaints/{document=**} {
      allow read, write: if request.auth != null;
    }

    match /bins/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'officer';
    }

    // Default deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
